{
  "name": "openclaw-wa-automation",
  "version": "0.1.0",
  "description": "OpenClaw WhatsApp auto-reply automation with Slack logging",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build --workspace=extensions/wa-slack-logger",
    "typecheck": "tsc --noEmit --project extensions/wa-slack-logger/tsconfig.json",
